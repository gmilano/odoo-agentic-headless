<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_agentic_request_log_list" model="ir.ui.view">
        <field name="name">agentic.request.log.list</field>
        <field name="model">agentic.request.log</field>
        <field name="arch" type="xml">
            <list string="Agentic Request Logs" decoration-success="ok" decoration-danger="not ok">
                <field name="create_date"/>
                <field name="endpoint"/>
                <field name="method"/>
                <field name="operation"/>
                <field name="model_name"/>
                <field name="status_code"/>
                <field name="ok"/>
                <field name="error_code"/>
                <field name="authenticated"/>
                <field name="remote_addr"/>
            </list>
        </field>
    </record>

    <record id="view_agentic_request_log_form" model="ir.ui.view">
        <field name="name">agentic.request.log.form</field>
        <field name="model">agentic.request.log</field>
        <field name="arch" type="xml">
            <form string="Agentic Request Log" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="endpoint"/>
                            <field name="method"/>
                            <field name="operation"/>
                            <field name="model_name"/>
                        </group>
                        <group>
                            <field name="status_code"/>
                            <field name="ok"/>
                            <field name="error_code"/>
                            <field name="authenticated"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload">
                            <field name="payload_json"/>
                        </page>
                        <page string="Response">
                            <field name="response_json"/>
                        </page>
                        <page string="Client">
                            <group>
                                <field name="remote_addr"/>
                                <field name="user_agent"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_agentic_request_log_search" model="ir.ui.view">
        <field name="name">agentic.request.log.search</field>
        <field name="model">agentic.request.log</field>
        <field name="arch" type="xml">
            <search string="Agentic Request Logs">
                <field name="endpoint"/>
                <field name="operation"/>
                <field name="model_name"/>
                <field name="error_code"/>
                <filter name="failed" string="Failed" domain="[('ok','=',False)]"/>
                <filter name="execute_plan" string="Execute Plan" domain="[('endpoint','=','/agentic/v1/execute_plan')]"/>
                <group>
                    <filter name="group_endpoint" string="Endpoint" context="{'group_by':'endpoint'}"/>
                    <filter name="group_status" string="Status Code" context="{'group_by':'status_code'}"/>
                    <filter name="group_model" string="Model" context="{'group_by':'model_name'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_agentic_request_logs" model="ir.actions.act_window">
        <field name="name">Agentic Audit Logs</field>
        <field name="res_model">agentic.request.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_execute_plan': 1}</field>
    </record>
</odoo>
